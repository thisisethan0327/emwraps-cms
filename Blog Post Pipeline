## Method 2: Scripted (For Bulk or Automated Posts)

For creating multiple posts at once, use the Node.js script approach.

### Prerequisites
- Node.js 22+ installed
- CMS running locally (`npm run dev -- --port 3001` in emwraps-cms)

### Script Template

Save this as `create-post.mjs` in the `emwraps-cms` folder:

```javascript
import fs from 'fs';
import path from 'path';

const CMS_URL = 'http://localhost:3001';
const CREDENTIALS = { email: 'admin@emwraps.net', password: 'YOUR_PASSWORD' };

let TOKEN = '';

// Login
async function login() {
    const res = await fetch(`${CMS_URL}/api/users/login`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(CREDENTIALS),
    });
    TOKEN = (await res.json()).token;
    console.log('✅ Logged in');
}

// Upload an image file → returns media doc
async function uploadImage(filePath, altText) {
    const form = new FormData();
    const blob = new Blob([fs.readFileSync(filePath)], { type: 'image/jpeg' });
    form.append('file', blob, path.basename(filePath));
    form.append('_payload', JSON.stringify({ alt: altText }));

    const res = await fetch(`${CMS_URL}/api/media`, {
        method: 'POST',
        headers: { 'Authorization': `JWT ${TOKEN}` },
        body: form,
    });
    const data = await res.json();
    console.log(`📸 Uploaded: ${path.basename(filePath)} → ID: ${data.doc.id}`);
    return data.doc;
}

// Lexical content helpers
const paragraph = (text) => ({
    type: 'paragraph',
    children: [{ type: 'text', text, format: 0, mode: 'normal', version: 1 }],
    direction: 'ltr', format: '', indent: 0, version: 1,
});

const heading = (text, tag = 'h2') => ({
    type: 'heading', tag,
    children: [{ type: 'text', text, format: 0, mode: 'normal', version: 1 }],
    direction: 'ltr', format: '', indent: 0, version: 1,
});

const uploadNode = (mediaId) => ({
    type: 'upload', relationTo: 'media', value: mediaId, format: '', version: 2,
});

// ── CREATE YOUR POST ──
async function main() {
    await login();

    // 1. Upload images
    const hero = await uploadImage('path/to/hero-image.jpg', 'BMW M4 satin black wrap — front view');
    const img2 = await uploadImage('path/to/detail.jpg', 'BMW M4 wrap — door panel detail');

    // 2. Get category ID
    const catRes = await fetch(`${CMS_URL}/api/categories?where[slug][equals]=project-spotlight`, {
        headers: { 'Authorization': `JWT ${TOKEN}` },
    });
    const categoryId = (await catRes.json()).docs[0]?.id;

    // 3. Create the post
    const res = await fetch(`${CMS_URL}/api/posts`, {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json',
            'Authorization': `JWT ${TOKEN}`,
        },
        body: JSON.stringify({
            title: 'BMW M4 — Satin Black Full Body Wrap',
            slug: 'bmw-m4-satin-black-full-body-wrap',
            excerpt: 'A stunning satin black vinyl wrap on a BMW M4 Competition. Full body coverage with 3M 2080 series.',
            status: 'published',
            _status: 'published',
            publishedAt: new Date().toISOString(),
            category: categoryId,
            relatedService: 'vinyl',
            author: 1,
            featuredImage: hero.id,
            tags: [{ tag: 'BMW' }, { tag: 'M4' }, { tag: 'Satin Black' }, { tag: 'Full Wrap' }],
            content: {
                root: {
                    type: 'root',
                    children: [
                        paragraph('This BMW M4 Competition received a full body wrap in 3M 2080 Satin Black...'),
                        heading('The Build'),
                        paragraph('Details about the build...'),
                        uploadNode(hero.id),
                        heading('The Result'),
                        paragraph('The final result is stunning...'),
                        uploadNode(img2.id),
                    ],
                    direction: 'ltr', format: '', indent: 0, version: 1,
                },
            },
        }),
    });

    const post = await res.json();
    console.log(`\n✅ Post created: "${post.doc.title}"`);
    console.log(`🔗 View at: http://localhost:5173/blog/${post.doc.slug}`);
}

main().catch(console.error);
```

### Run It
```bash
cd emwraps-cms
node create-post.mjs
```

