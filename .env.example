# ── Payload CMS ──
PAYLOAD_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# ── Database (Supabase Postgres) ──
# Get from: Supabase Dashboard → Settings → Database → Connection String (URI)
DATABASE_URI=postgresql://postgres.[YOUR_REF]:[YOUR_PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# ── S3 Storage (Supabase Storage) ──
# Get from: Supabase Dashboard → Settings → Storage → S3 Connection
S3_ENDPOINT=https://[YOUR_REF].supabase.co/storage/v1/s3
S3_ACCESS_KEY_ID=your_s3_access_key
S3_SECRET_ACCESS_KEY=your_s3_secret_key
S3_BUCKET=cms-media
S3_REGION=us-east-1

# ── App ──
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
CORS_ORIGINS=https://emwraps.net
